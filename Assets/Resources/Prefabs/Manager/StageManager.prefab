  chapters:
  - chapterIndex: 1
    chapterName: SceneName/Stage1_1
    chapterDescription: "\uC2F1\uADF8\uB7EC\uC6B4 \uC0B0\uB538\uAE30\uC640 \uC78E\uC0AC\uADC0\uAC00
      \uAC00\uB4DD\uD55C \uB18D\uC7A5.\r\n\uAC00\uC6B4\uB370\uC5D0 \uD0D0\uC2A4\uB7EC\uC6B4
      \uC655\uB2F9\uADFC\uC774 \uBB35\uC9C1\uD558\uAC8C \uC790\uB77C\uACE0 \uC788\uB2E4.\r\n\uD3C9\uD654\uB85C\uC6CC
      \uBCF4\uC774\uC9C0\uB9CC \uBAA8\uB450 \uC655\uB2F9\uADFC\uC744 \uD638\uC2DC\uD0D0\uD0D0
      \uB178\uB9AC\uACE0 \uC788\uB2E4."
    chapterThumbnail: {fileID: 21300000, guid: 78afe28990a9a7a42a7ffe2fc2a06c10, type: 3}
